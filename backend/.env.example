# Copy to backend/.env (gitignored) and fill in. Names are fixed by CONTRACTS.md §8.
MONGODB_URI=
MONGODB_DB=reeled_in
HF_TOKEN=
ELEVENLABS_API_KEY=
BACKBOARD_API_KEY=
GEMINI_API_KEY=
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
ALLOWED_ORIGINS=          # comma-separated Base44 app origin(s) C allows via CORS (e.g. https://<app>.base44.app)
AUTH0_DOMAIN=             # C verifies IdP JWTs against this domain's JWKS
AUTH0_AUDIENCE=           # expected `aud` claim on the JWT
# BACKEND_API_KEY removed for the free-plan build (no server-side courier; Builder-plan-only). See CONTRACTS.md §6.
# VOYAGE_API_KEY=         # only if adding Atlas Vector Search RAG over test history (PERSON_C_PLAN.md §5.2)
